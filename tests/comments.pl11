% comments.pl11 — Test UNH comment forms:
%   1.  COMMENT ... ; keyword comment terminated by semicolon
%   2.  % ...         line comment (this very line is one)

BEGIN
    WORD A, B, RESULT;

    COMMENT Set up operands;
    10 => A;
    32 => B;

    A + B => RESULT;    % should be 42

    COMMENT This comment spans
            multiple lines and ends
            at the semicolon;

    RESULT + 0 => RESULT;   % no-op, just proves we reach this line

    PRINT('Result: %d\n', RESULT)   % expects 42
END
