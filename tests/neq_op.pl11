% neq_op.pl11 — Verify the /= not-equal operator.

BEGIN
    WORD X, Y, COUNT, A, B, T;

    COMMENT /= used in IF condition;
    5 => X;
    3 => Y;
    IF X /= Y THEN
        PRINT('5 /= 3: true\n')
    ELSE
        PRINT('5 /= 3: false\n');

    COMMENT /= used in WHILE condition (GCD via Euclidean algorithm);
    48 => A;
    18 => B;
    WHILE B /= 0 DO
        BEGIN
            A MOD B => T;
            B       => A;
            T       => B
        END;
    PRINT('GCD(48,18) = %d\n', A);   % expects 6

    COMMENT /= in WHILE: count down while X is non-zero;
    5 => X;
    0 => COUNT;
    WHILE X /= 0 DO
        BEGIN
            X - 1     => X;
            COUNT + 1 => COUNT
        END;
    PRINT('Count to zero: %d steps\n', COUNT)   % expects 5

END
