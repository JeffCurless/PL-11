% gcd.pl11 — Greatest common divisor using Euclidean algorithm

BEGIN
    WORD PROCEDURE GCD (IN WORD A, IN WORD B);
    BEGIN
        WORD R;
        WHILE B /= 0 DO
            BEGIN
                A MOD B => R;
                B       => A;
                R       => B
            END;
        RETURN(A)
    END;

    WORD X, Y, G;
    48       => X;
    18       => Y;
    GCD(X, Y) => G
    % G = 6
END
