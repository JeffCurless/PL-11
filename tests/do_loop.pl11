BEGIN
    INTEGER I;
    INTEGER SUM;

    % Test 1: DO ; UNTIL — empty body; condition is already true, exits at once
    5 => I;
    DO ;
    UNTIL I = 5;
    PRINT('%d\n', I);

    % Test 2: DO stmt UNTIL — body runs at least once, accumulates 1+2+3+4+5 = 15
    1 => I;
    0 => SUM;
    DO
        BEGIN
            SUM + I => SUM;
            I + 1   => I
        END
    UNTIL I > 5;
    PRINT('%d\n', SUM)
END
