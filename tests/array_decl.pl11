% array_decl.pl11 — Test the UNH array declaration syntax: TYPE size ARRAY name

BEGIN
    COMMENT Single-dimension arrays using the UNH ARRAY syntax;
    WORD 5 ARRAY values;
    BYTE 3 ARRAY flags;

    COMMENT Multiple names sharing the same size and type;
    WORD 4 ARRAY row, col;

    COMMENT 2-D array: 3 rows x 4 cols = 12 elements (flat layout);
    WORD 3, 4 ARRAY grid;

    WORD I, J, SUM;

    COMMENT Fill values with 1..5 and sum them (should be 15);
    FOR I FROM 1 TO 5 DO
        I => values(I);

    0 => SUM;
    FOR I FROM 1 TO 5 DO
        SUM + values(I) => SUM;
    PRINT('Sum 1-5: %d\n', SUM);

    COMMENT Verify flags array;
    10 => flags(1);
    20 => flags(2);
    30 => flags(3);
    PRINT('Flags: %d %d %d\n', flags(1), flags(2), flags(3));

    COMMENT Verify multiple-name declaration;
    7 => row(1);
    3 => col(1);
    PRINT('Row: %d  Col: %d\n', row(1), col(1));

    COMMENT Fill 3x4 grid with row*10 + col and check one element;
    FOR I FROM 1 TO 3 DO
        FOR J FROM 1 TO 4 DO
            I * 10 + J => grid((I - 1) * 4 + J);
    PRINT('Grid[2,3]: %d\n', grid((2 - 1) * 4 + 3))

END
