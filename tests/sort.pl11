% sort.pl11 — Bubble sort on an integer array
% Note: this compiler requires array dimensions to be integer literals

BEGIN
    CONSTANT WORD N = 8;
    WORD A(8), I, J, TEMP;

    % Initialize with values in reverse order
    FOR I FROM 1 TO N DO
        N - I + 1 => A(I);

    % Bubble sort
    FOR I FROM 1 TO N - 1 DO
        FOR J FROM 1 TO N - I DO
            IF A(J) > A(J + 1) THEN
                BEGIN
                    A(J)     => TEMP;
                    A(J + 1) => A(J);
                    TEMP     => A(J + 1)
                END

    % A is now sorted 1..N
END
