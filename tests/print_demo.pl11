% print_demo.pl11 — Demonstrates the PRINT statement

BEGIN
    WORD  I;
    LONG  FACT;
    LONG  BIG;
    REAL  PI;
    BYTE  CH;

    % Plain string
    PRINT('PL-11 PRINT demo\n');

    % %d: WORD decimal
    42 => I;
    PRINT('Answer: %d\n', I);

    % %d with expression
    PRINT('6 * 7 = %d\n', 6 * 7);

    % %l: LONG decimal
    75000 => BIG;
    PRINT('Big: %l\n', BIG);

    % %f: REAL floating-point
    3.14159 => PI;
    PRINT('Pi ~ %f\n', PI);

    % %c: character from integer code
    65 => CH;
    PRINT('Letter: %c\n', CH);

    % %% escaping
    PRINT('100%% complete\n');

    % Factorial loop with PRINT — LONG holds up to 12! cleanly
    1 => FACT;
    FOR I FROM 1 TO 12 DO
        BEGIN
            FACT * I => FACT;
            PRINT('%d! = %l\n', I, FACT)
        END
END
