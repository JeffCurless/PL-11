% for_nostart.pl11 — FOR loops that omit the start assignment and use the
%                    variable's current value as the initial loop counter.
%
% Syntax forms exercised:
%   FOR var TO end DO stmt              (start = current, step = +1)
%   FOR var DOWNTO end DO stmt          (start = current, step = -1)
%   FOR var STEP n TO end DO stmt       (start = current, explicit step)
%   FOR var STEP n DOWNTO end DO stmt   (start = current, explicit negative step)
%   … combined with UNTIL

BEGIN
    WORD I, SUM;

    COMMENT TO with no start: count up from 3 to 7, sum = 3+4+5+6+7 = 25;
    3 => I;
    0 => SUM;
    FOR I TO 7 DO
        SUM + I => SUM;
    PRINT('TO no-start (3..7):        %d\n', SUM);    % expects 25

    COMMENT DOWNTO with no start: count down from 5 to 1, sum = 5+4+3+2+1 = 15;
    5 => I;
    0 => SUM;
    FOR I DOWNTO 1 DO
        SUM + I => SUM;
    PRINT('DOWNTO no-start (5..1):    %d\n', SUM);    % expects 15

    COMMENT STEP 3 TO with no start: 2 5 8 11 = 26;
    2  => I;
    0  => SUM;
    FOR I STEP 3 TO 11 DO
        SUM + I => SUM;
    PRINT('STEP 3 no-start (2..11):   %d\n', SUM);    % expects 26

    COMMENT STEP -2 DOWNTO with no start: 10 8 6 4 2 = 30;
    10 => I;
    0  => SUM;
    FOR I STEP -2 DOWNTO 2 DO
        SUM + I => SUM;
    PRINT('STEP -2 no-start (10..2):  %d\n', SUM);    % expects 30

    COMMENT No-start with UNTIL: sum from current I=1 upwards, stop when SUM > 10;
    1 => I;
    0 => SUM;
    FOR I TO 100 DO
        SUM + I => SUM
    UNTIL SUM > 10;
    PRINT('No-start UNTIL SUM>10:     %d\n', SUM);    % expects 15 (1+2+3+4+5)

    COMMENT After the loop I holds its exit value — verify it;
    PRINT('Loop var after UNTIL:       %d\n', I)       % expects 5

END
