% for_step.pl11 — Test the UNH FROM / STEP FOR loop syntax

BEGIN
    WORD I, SUM;

    COMMENT FROM without STEP (default step = +1);
    0 => SUM;
    FOR I FROM 1 TO 5 DO
        SUM + I => SUM;
    PRINT('Traditional TO:   %d\n', SUM);     % expects 15

    COMMENT FROM without STEP (same range, verify repeat);
    0 => SUM;
    FOR I FROM 1 TO 5 DO
        SUM + I => SUM;
    PRINT('FROM TO:          %d\n', SUM);      % expects 15

    COMMENT FROM without STEP, DOWNTO (default step = -1);
    0 => SUM;
    FOR I FROM 5 DOWNTO 1 DO
        SUM + I => SUM;
    PRINT('FROM DOWNTO:      %d\n', SUM);      % expects 15

    COMMENT FROM with explicit STEP +2 — sum of odd numbers 1 3 5 7 9;
    0 => SUM;
    FOR I FROM 1 STEP 2 TO 9 DO
        SUM + I => SUM;
    PRINT('FROM STEP 2 TO:   %d\n', SUM);      % expects 25

    COMMENT FROM with explicit STEP -1 DOWNTO;
    0 => SUM;
    FOR I FROM 5 STEP -1 DOWNTO 1 DO
        SUM + I => SUM;
    PRINT('FROM STEP -1 DOWNTO: %d\n', SUM);  % expects 15

    COMMENT FROM STEP -2 counting down by twos: 10 8 6 4 2;
    0 => SUM;
    FOR I FROM 10 STEP -2 DOWNTO 2 DO
        SUM + I => SUM;
    PRINT('FROM STEP -2 DOWNTO: %d\n', SUM);  % expects 30

    COMMENT FROM STEP with UNTIL early exit: sum until > 20;
    0 => SUM;
    FOR I FROM 1 STEP 3 TO 100 DO
        SUM + I => SUM
    UNTIL SUM > 20;
    PRINT('FROM STEP UNTIL:  %d\n', SUM)       % expects 22 (1+4+7+10 = 22 > 20)

END
